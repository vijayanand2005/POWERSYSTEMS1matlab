% Fast Decoupled Load Flow (FDLF)
% 2-Bus System
% X = 0.1 pu

clc;
clear;
close all;

X = 0.1;          % Line reactance (pu)

% B' and B'' matrices
Bp = 1/X;         % B' matrix
Bpp = 1/X;        % B'' matrix

disp('B'' Matrix = ');
disp(Bp);

disp('B'''' Matrix = ');
disp(Bpp);

% Comparison for contingency analysis
GS_iterations = 120;   % Typical for 50-bus system
FDLF_iterations = 6;   % Typical for 50-bus system

fprintf('\nGauss-Seidel Iterations = %d\n', GS_iterations);
fprintf('FDLF Iterations = %d\n', FDLF_iterations);

if FDLF_iterations < GS_iterations
    disp('FDLF is computationally superior for large power systems.');
end
